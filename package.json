{
  "name": "test-capture",
  "version": "0.1.0",
  "description": "Agent-native local browser verification capture for generating maintainable tests.",
  "type": "module",
  "bin": {
    "test-capture": "./bin/test-capture.js"
  },
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "doctor": "node ./bin/test-capture.js doctor"
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "playwright": ">=1.44.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "license": "MIT"
}
