{
  "name": "test-capture",
  "version": "0.1.0",
  "description": "Agent-native local browser verification capture for generating maintainable tests.",
  "type": "module",
  "bin": {
    "test-capture": "./bin/test-capture.js"
  },
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "doctor": "node ./bin/test-capture.js doctor",
    "install:codex-skill": "node ./scripts/install-codex-skill.mjs",
    "install:claude-skill": "node ./scripts/install-claude-skill.mjs",
    "capture-target:install": "npm install --prefix examples/capture-target",
    "capture-target:dev": "npm run dev --prefix examples/capture-target",
    "capture-target:build": "npm run build --prefix examples/capture-target"
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "playwright": ">=1.44.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "license": "MIT",
  "devDependencies": {
    "playwright": "^1.60.0"
  }
}
